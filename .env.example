# ─────────────────────────────────────────────────────────────────────────────
# Delhi HC Case Tracker — environment variables
# Copy this file to `.env` at the project root and fill in real values.
# NEVER commit `.env`. The .gitignore already excludes it.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                                # development | staging | production
APP_NAME=delhi-hc-case-tracker
APP_LOG_LEVEL=INFO                                 # DEBUG | INFO | WARNING | ERROR
APP_TIMEZONE=Asia/Kolkata

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000         # comma-separated for prod

# ── Database ──────────────────────────────────────────────────────────────────
# MVP: SQLite. v2: switch DATABASE_URL to postgresql+asyncpg://...
DATABASE_URL=sqlite+aiosqlite:///./backend/data/dhc.db
DATABASE_ECHO=false                                # true to log all SQL (dev only)

# ── Session store ─────────────────────────────────────────────────────────────
# MVP: in-process dict + SQLite spillover. Production: Redis.
SESSION_BACKEND=memory                             # memory | redis
SESSION_TTL_SECONDS=600                            # 10 min default
SESSION_CAPTCHA_TTL_SECONDS=180                    # 3 min for CAPTCHA freshness
REDIS_URL=redis://localhost:6379/0                 # ignored when SESSION_BACKEND=memory

# ── Court client selection ───────────────────────────────────────────────────
# fake → FakeCourtClient (fixtures; safe default, never touches the wire).
# real → DelhiHCClient (currently STUBBED — pending Arnav's Phase-0 spike;
#         see docs/SPIKE-REPORT.md). Setting `real` will log a loud WARNING
#         at startup; any actual outbound call raises NotImplementedError.
# Keep in sync with NEXT_PUBLIC_CLIENT_MODE at the bottom of this file.
CLIENT_MODE=fake                                   # fake | real

# ── Outbound: Delhi High Court ────────────────────────────────────────────────
# Base URL — VERIFY in feasibility spike (see Arnav's ADR-003).
DHC_BASE_URL=https://delhihighcourt.nic.in
DHC_USER_AGENT=DelhiHCCaseTracker/0.1 (+https://example.com/contact)
DHC_OUTBOUND_TIMEOUT_SECONDS=20
DHC_OUTBOUND_MAX_CONCURRENT=4                      # global cap; polite client
DHC_OUTBOUND_RATE_LIMIT_PER_SEC=0.33               # ≤ 1 outbound search / 3 sec
DHC_RESPECT_ROBOTS_TXT=true                        # kill switch if disallowed
DHC_HOSTNAME_ALLOWLIST=delhihighcourt.nic.in       # comma-separated; SSRF guard

# ── Kill switch (Sneha's compliance design) ──────────────────────────────────
# Global emergency stop — flip to `false` to halt every outbound call.
# Used when court issues take-down OR ToS review flips negative. Flip via
# admin endpoint `POST /admin/kill-switch` (gated by ADMIN_SHARED_SECRET).
OUTBOUND_FETCH_ENABLED=true

# ── Caching ───────────────────────────────────────────────────────────────────
PARSED_CASE_CACHE_TTL_SECONDS=86400                # 24 hours
CACHE_BACKEND=memory                               # memory | redis

# ── Admin ─────────────────────────────────────────────────────────────────────
# Shared secret for /admin/* endpoints. Rotate quarterly. No user auth in v1.
ADMIN_SHARED_SECRET=change-me-before-deploy

# ── Observability ─────────────────────────────────────────────────────────────
LOG_FILE_BACKEND=logs/backend/app.log
LOG_FILE_OUTBOUND=logs/backend/outbound.log
SENTRY_DSN=                                         # leave empty to disable

# ── Frontend (Next.js — copy relevant values to frontend/.env.local) ──────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_NAME=Delhi HC Case Tracker
NEXT_PUBLIC_DISCLAIMER_VERSION=v1.0                 # bump when disclaimer text changes

# Client-data mode mirror for the frontend (GREEN-ZONE rail).
# MUST match the backend's CLIENT_MODE. When set to `real`, the frontend
# renders the "PRIVATE ALPHA — DO NOT SHARE" banner on every page. Any other
# value (fake / unset) hides the banner. Inlined at build time by Next.js.
NEXT_PUBLIC_CLIENT_MODE=fake                        # fake | real
