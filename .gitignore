# ── Secrets — never commit ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example
**/secrets/*
*.pem
*.key
!*.key.example

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# ── Node / Next.js ────────────────────────────────────────────────────────────
node_modules/
.next/
out/
dist/
build/
*.tsbuildinfo
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Databases (MVP uses SQLite — never commit data) ──────────────────────────
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-wal
*.db-shm
backend/data/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/*.log
logs/**/*.log
!logs/.gitkeep
!logs/**/.gitkeep

# ── Parser fixtures — keep golden HTML, exclude scratch dumps ────────────────
parsers/fixtures/scratch/

# ── Docker / infra ────────────────────────────────────────────────────────────
.docker-data/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# ── Local override files ──────────────────────────────────────────────────────
docker-compose.override.yml
docker-compose.local.yml
