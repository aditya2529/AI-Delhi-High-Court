{
  "name": "delhi-hc-case-tracker-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Next.js frontend for the Delhi HC Case Tracker MVP. Workflow-simplification UI over the public Delhi High Court case-status search.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
