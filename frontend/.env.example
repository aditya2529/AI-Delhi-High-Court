# =============================================================================
# Delhi HC Case Tracker -- FRONTEND environment variables
# -----------------------------------------------------------------------------
# Copy this file to `frontend/.env.local` (Next.js only reads .env.local,
# .env.development.local, etc. -- it does NOT read the repo-root .env file).
#
#   Windows: setup.ps1 does this copy for you.
#   Unix:    setup.sh  does this copy for you.
#
# Why a separate file?
# --------------------
# Next.js loads env files from its own working directory (frontend/) and
# only inlines variables prefixed with `NEXT_PUBLIC_` into the browser
# bundle. Putting `NEXT_PUBLIC_*` in the repo-root .env does NOT reach the
# UI -- this bit the founder during the first manual demo (the PRIVATE
# ALPHA banner never appeared because NEXT_PUBLIC_CLIENT_MODE was only in
# the root .env). After the env-layout split:
#
#   .env                  <- backend-only variables (FastAPI / outbound / DB)
#   frontend/.env.local   <- frontend-only NEXT_PUBLIC_* variables (this file)
#
# Keep them in sync: any NEXT_PUBLIC_CLIENT_MODE here MUST match CLIENT_MODE
# in the root .env, or the banner and backend will disagree.
#
# NEVER commit `.env.local`. It is gitignored.
# =============================================================================

# Base URL of the FastAPI backend. The Next.js rewrites in next.config.js
# proxy /api/proxy/* to this host. In dev: http://localhost:8000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Display name for the site (header, browser tab title fallback).
NEXT_PUBLIC_SITE_NAME=Delhi HC Case Tracker

# Bump when the user-facing disclaimer text changes; the UI invalidates
# the dismissal cookie so users re-consent.
NEXT_PUBLIC_DISCLAIMER_VERSION=v1.0

# -----------------------------------------------------------------------------
# Client-data mode mirror (GREEN-ZONE rail)
# -----------------------------------------------------------------------------
# MUST match the backend's CLIENT_MODE (in the repo-root .env). When set to
# the literal string `real`, the frontend renders the "PRIVATE ALPHA -- DO
# NOT SHARE" banner on every page (see PrivateAlphaBanner.tsx).
#
# Any other value (`fake`, empty, unset, typos) hides the banner. The banner
# is a UX warning, not a security control -- the real "do not call live
# court" guard lives in the backend kill-switch.
#
# IMPORTANT: Next.js inlines NEXT_PUBLIC_* values AT BUILD TIME for the
# production bundle. After changing this value, restart `npm run dev` so the
# dev server picks it up.
NEXT_PUBLIC_CLIENT_MODE=fake
